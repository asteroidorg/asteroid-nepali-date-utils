{
  "name": "@asteroidstudio/date-utils",
  "version": "0.0.2",
  "description": "Library for handling nepali date",
  "keywords": [
    "nepali",
    "calendar",
    "date"
  ],
  "bugs": {
    "url": "https://github.com/asteroidorg/asteroid-nepali-date-utils/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asteroidorg/asteroid-nepali-date-utils.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "asteroidstudio",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0"
  }
}
